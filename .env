## LLM API Monitor (Go)
## 端口 8788 避免与 Python 版本 (8787) 冲突

LLM_MONITOR_HOST=0.0.0.0
LLM_MONITOR_PORT=8789
LLM_MONITOR_IFACE=enp1s0f3

LLM_MONITOR_DATA_DIR=/data/llm_api_monitor_runtime/data
LLM_MONITOR_LOG_DIR=/data/llm_api_monitor_runtime/logs
LLM_MONITOR_CAPTURE_DIR=/data/llm_api_monitor/captures
LLM_MONITOR_STATIC_DIR=/root/llm_api_monitor_go/static

LLM_MONITOR_WINDOW_SECONDS=60
LLM_MONITOR_BPF=port 443 and (host api.openai.com or host api.anthropic.com or host generativelanguage.googleapis.com or host api.deepseek.com or host dashscope.aliyuncs.com or host open.bigmodel.cn or host api.moonshot.cn or host ark.cn-beijing.volces.com or host api.minimax.io or host api.x.ai or host accounts.x.ai or host grok.com or host api.mistral.ai or host api.cohere.com or host llm-api-proxy.hnfunny.com)
LLM_MONITOR_SNAPLEN=0

## 完整模式：启动抓包 + 解析 + 写入
LLM_MONITOR_AUTOSTART=1
LLM_MONITOR_RETAIN_PARSED_PCAP=0
LLM_MONITOR_MAX_PENDING_SEGMENTS=0
LLM_MONITOR_BACKFILL_PAUSE_ON_REALTIME=1

LLM_MONITOR_REALTIME_WORKERS=8
LLM_MONITOR_BACKFILL_WORKERS=0

LLM_MONITOR_MYSQL_HOST=127.0.0.1
LLM_MONITOR_MYSQL_PORT=3306
LLM_MONITOR_MYSQL_USER=root
LLM_MONITOR_MYSQL_PASSWORD=123456
LLM_MONITOR_MYSQL_DATABASE=llm_api_monitor
LLM_MONITOR_MYSQL_MAX_OPEN=20
LLM_MONITOR_MYSQL_MAX_IDLE=10

LLM_MONITOR_REDIS_HOST=127.0.0.1
LLM_MONITOR_REDIS_PORT=6379
LLM_MONITOR_REDIS_PASSWORD=123456
LLM_MONITOR_REDIS_DB=0
LLM_MONITOR_REDIS_ENABLED=1

LLM_MONITOR_TARGET_IP_HINTS_CACHE_TTL_SECONDS=3600
